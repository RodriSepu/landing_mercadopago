        <style>
          .flow-dot {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 9999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 0.95rem;
            flex: 0 0 auto;
            border: 1px solid transparent;
          }
          .flow-dot--active {
            background: #003fb1;
            color: #ffffff;
            box-shadow: 0 8px 20px rgba(0, 63, 177, 0.18);
          }
          .flow-dot--done {
            background: #003fb1;
            color: #ffffff;
            opacity: 0.75;
          }
          .flow-dot--idle {
            background: rgba(219, 225, 255, 0.55);
            color: rgba(0, 63, 177, 0.38);
          }
          .flow-line {
            height: 2px;
            flex: 1 1 auto;
            background: linear-gradient(
              90deg,
              rgba(0, 63, 177, 0.45),
              rgba(0, 63, 177, 0.12)
            );
            margin: 0 0.45rem;
            border-radius: 9999px;
          }
        </style>
        <script>
          const form = document.querySelector("#debt-form");
          const rutInput = document.querySelector("#rut");
          const emailInput = document.querySelector("#email");
          const messageArea = document.querySelector("#message-area");
          const loadingState = document.querySelector("#loading-state");
          const reviewButton = document.querySelector("#review-button");
          const payButton = document.querySelector("#pay-button");
          const resultCard = document.querySelector("#result-card");
          const debtName = document.querySelector("#debt-name");
          const debtAmount = document.querySelector("#debt-amount");
          const debtBreakdown = document.querySelector("#debt-breakdown");
          const breakdownTitle = document.querySelector("#breakdown-title");
          const flowStep1 = document.querySelector("#flow-step-1");
          const flowStep2 = document.querySelector("#flow-step-2");
          const flowStep3 = document.querySelector("#flow-step-3");

          const tabRut = document.querySelector("#tab-rut");
          const tabEmail = document.querySelector("#tab-email");
          const containerRut = document.querySelector("#container-rut");
          const containerEmail = document.querySelector("#container-email");

          const loadingOverlay = document.querySelector("#loading-overlay");

          const currency = new Intl.NumberFormat("es-CL", {
            currency: "CLP",
            maximumFractionDigits: 0,
            style: "currency",
          });

          let activeMode: "rut" | "email" = "rut";
          let payableRut = "";
          let payableEmail = "";
          let currentFlowStep: 1 | 2 | 3 = 1;

          const cleanRut = (value: string) =>
            value.replace(/[.\s]/g, "").toUpperCase();

          const formatRut = (value: string) => {
            const cleaned = cleanRut(value);
            const match = cleaned.match(/^(\d{1,8})([\dK])?$/);

            if (!match) {
              return value;
            }

            const body = match[1];
            const dv = match[2] ? `-${match[2]}` : "";
            const groups: string[] = [];

            if (body.length <= 2) {
              groups.push(body);
            } else {
              groups.push(body.slice(0, 2));
              groups.push(body.slice(2, 5));
              groups.push(body.slice(5, 8));
            }

            return `${groups.filter(Boolean).join(".")}${dv}`;
          };

          const attachRutFormatter = () => {
            if (!(rutInput instanceof HTMLInputElement)) {
              return;
            }

            rutInput.addEventListener("input", () => {
              const cursorAtEnd =
                rutInput.selectionStart === rutInput.value.length &&
                rutInput.selectionEnd === rutInput.value.length;
              const formatted = formatRut(rutInput.value);
              rutInput.value = formatted;
              if (cursorAtEnd) {
                rutInput.setSelectionRange(formatted.length, formatted.length);
              }
            });
          };

          attachRutFormatter();

          const setFlowStep = (step: 1 | 2 | 3) => {
            currentFlowStep = step;
            const steps = [flowStep1, flowStep2, flowStep3];

            steps.forEach((element, index) => {
              if (!(element instanceof HTMLElement)) {
                return;
              }

              const stepNumber = (index + 1) as 1 | 2 | 3;
              element.classList.remove(
                "flow-dot--active",
                "flow-dot--done",
                "flow-dot--idle",
              );

              if (stepNumber < step) {
                element.classList.add("flow-dot--done");
              } else if (stepNumber === step) {
                element.classList.add("flow-dot--active");
              } else {
                element.classList.add("flow-dot--idle");
              }
            });
          };

          const showOverlay = () => {
            if (!(loadingOverlay instanceof HTMLElement)) return;

            loadingOverlay.classList.remove("hidden");
            loadingOverlay.classList.add("flex");
            // trigger transition
            requestAnimationFrame(() => {
              loadingOverlay.classList.remove("opacity-0");
              loadingOverlay.classList.add("opacity-100");
              const content = loadingOverlay.firstElementChild;
              if (content) {
                content.classList.remove("scale-95");
                content.classList.add("scale-100");
              }
            });
          };

          const hideOverlay = async () => {
            if (!(loadingOverlay instanceof HTMLElement)) return;

            loadingOverlay.classList.remove("opacity-100");
            loadingOverlay.classList.add("opacity-0");
            const content = loadingOverlay.firstElementChild;
            if (content) {
              content.classList.remove("scale-100");
              content.classList.add("scale-95");
            }

            return new Promise<void>((resolve) => {
              setTimeout(() => {
                loadingOverlay.classList.remove("flex");
                loadingOverlay.classList.add("hidden");
                resolve();
              }, 300); // matches duration-300
            });
          };

          const setLoading = (isLoading: boolean) => {
            if (isLoading) {
              showOverlay();
            }
            if (reviewButton instanceof HTMLButtonElement) {
              reviewButton.disabled = isLoading;
            }
          };

          const setMessage = (
            type: "error" | "info" | "neutral" | "success",
            text: string,
          ) => {
            if (!(messageArea instanceof HTMLElement)) {
              return;
            }

            const styles: Record<
              "error" | "info" | "neutral" | "success",
              string
            > = {
              error:
                "mt-5 min-h-12 rounded-lg border border-[#fecaca] bg-[#fef2f2] p-4 text-sm font-bold text-[#991b1b]",
              info: "mt-5 min-h-12 rounded-lg border border-[#dbeafe] bg-[#eff6ff] p-4 text-sm font-semibold text-[#1e40af]",
              neutral:
                "mt-5 min-h-12 rounded-2xl border border-[#e5e7eb] bg-[#f9fafb] p-4 text-sm font-medium text-[#374151] shadow-sm",
              success:
                "mt-5 min-h-12 rounded-lg border border-[#bbf7d0] bg-[#f0fdf4] p-4 text-sm font-semibold text-[#166534]",
            };

            messageArea.className = styles[type] ?? styles.neutral;
            if (type === "neutral") {
              messageArea.innerHTML = `
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined mt-0.5 text-[20px] text-[#6b7280]">info</span>
                  <div>
                    <p class="font-semibold text-[#111827]">${text}</p>
                    <p class="mt-1 text-xs text-[#6b7280]">Si esperabas un resultado distinto, revisa el RUT o el correo ingresado.</p>
                  </div>
                </div>
              `;
              return;
            }

            messageArea.textContent = text;
          };

          const hideResult = () => {
            if (resultCard instanceof HTMLElement) {
              resultCard.classList.add("hidden");
            }
            if (payButton instanceof HTMLButtonElement) {
              payButton.disabled = false;
            }
            if (reviewButton instanceof HTMLButtonElement) {
              reviewButton.hidden = false;
              reviewButton.classList.remove("hidden");
            }
          };

          const setMode = (mode: "rut" | "email") => {
            setFlowStep(1);
            activeMode = mode;
            if (mode === "rut") {
              tabRut?.classList.add(
                "font-bold",
                "text-[#003fb1]",
                "border-[#003fb1]",
              );
              tabRut?.classList.remove(
                "font-semibold",
                "text-[#737686]",
                "border-transparent",
              );
              tabEmail?.classList.remove(
                "font-bold",
                "text-[#003fb1]",
                "border-[#003fb1]",
              );
              tabEmail?.classList.add(
                "font-semibold",
                "text-[#737686]",
                "border-transparent",
              );

              containerRut?.classList.remove("hidden");
              containerEmail?.classList.add("hidden");

              if (rutInput instanceof HTMLInputElement) {
                rutInput.required = true;
              }
              if (emailInput instanceof HTMLInputElement) {
                emailInput.required = false;
                emailInput.value = "";
              }
            } else {
              tabEmail?.classList.add(
                "font-bold",
                "text-[#003fb1]",
                "border-[#003fb1]",
              );
              tabEmail?.classList.remove(
                "font-semibold",
                "text-[#737686]",
                "border-transparent",
              );
              tabRut?.classList.remove(
                "font-bold",
                "text-[#003fb1]",
                "border-[#003fb1]",
              );
              tabRut?.classList.add(
                "font-semibold",
                "text-[#737686]",
                "border-transparent",
              );

              containerEmail?.classList.remove("hidden");
              containerRut?.classList.add("hidden");

              if (emailInput instanceof HTMLInputElement) {
                emailInput.required = true;
              }
              if (rutInput instanceof HTMLInputElement) {
                rutInput.required = false;
                rutInput.value = "";
              }
            }
            hideResult();
          };

          tabRut?.addEventListener("click", () => setMode("rut"));
          tabEmail?.addEventListener("click", () => setMode("email"));

          form?.addEventListener("submit", async (event) => {
            event.preventDefault();

            if (
              !(rutInput instanceof HTMLInputElement) ||
              !(emailInput instanceof HTMLInputElement)
            ) {
              return;
            }

            setFlowStep(1);
            hideResult();
            setLoading(true);

            const requestBody =
              activeMode === "rut"
                ? { rut: rutInput.value }
                : { email: emailInput.value };

            try {
              const response = await fetch("/api/deudor", {
                method: "POST",
                headers: {
                  "content-type": "application/json",
                },
                body: JSON.stringify(requestBody),
              });

              const data = (await response.json()) as {
                found: boolean;
                nombre?: string;
                monto?: number;
                items?: Array<{
                  c_invoice_id: number;
                  fecha_docto?: string | null;
                  fecha_vencimiento?: string | null;
                  monto: number;
                }>;
                gestion_items?: Array<{
                  c_invoice_id: number;
                  fecha_docto?: string | null;
                  fecha_vencimiento?: string | null;
                  monto: number;
                }>;
                error?: string;
              };

              if (!response.ok) {
                await hideOverlay();
                if (data.error === "rut_invalido") {
                  setMessage("error", "El RUT ingresado no es valido.");
                  return;
                }
                if (data.error === "email_invalido") {
                  setMessage(
                    "error",
                    "El correo electrónico ingresado no es valido.",
                  );
                  return;
                }
                if (data.error === "db_no_configurada") {
                  setMessage(
                    "error",
                    "La base de datos no esta disponible en este entorno.",
                  );
                  return;
                }
                if (data.error === "db_error") {
                  setMessage(
                    "error",
                    "La tabla de deudas no esta disponible para la consulta.",
                  );
                  return;
                }
                setMessage("error", "No fue posible realizar la consulta.");
                return;
              }

              if (!data.found) {
                await hideOverlay();
                setMessage(
                  "neutral",
                  "No encontramos deudas pendientes asociadas a los datos ingresados.",
                );
                return;
              }

              payableRut = activeMode === "rut" ? rutInput.value : "";
              payableEmail = activeMode === "email" ? emailInput.value : "";

              const overdueItems = data.items ?? [];
              const gestionItems = data.gestion_items ?? [];
              const hasPayableItems = overdueItems.length > 0;

              setFlowStep(2);

              if (debtName instanceof HTMLElement && data.nombre) {
                debtName.textContent = data.nombre;
              }
              if (
                debtAmount instanceof HTMLElement &&
                data.monto !== undefined &&
                hasPayableItems
              ) {
                debtAmount.textContent = currency.format(data.monto);
              } else if (
                debtAmount instanceof HTMLElement &&
                !hasPayableItems
              ) {
                debtAmount.textContent = "";
              }
              if (debtBreakdown instanceof HTMLElement) {
                debtBreakdown.innerHTML = "";
                if (breakdownTitle instanceof HTMLElement) {
                  breakdownTitle.textContent = hasPayableItems
                    ? (overdueItems.length === 1
                        ? "Documento pendiente"
                        : "Documentos pendientes"
                      ).toUpperCase()
                    : "Documento en proceso de gestión de cobro";
                }
                if (hasPayableItems) {
                  for (const item of overdueItems) {
                    const row = document.createElement("article");
                    row.className =
                      "rounded-2xl border border-[#e2e8f0]/80 bg-white p-5 sm:p-6 shadow-sm flex justify-between items-start gap-4";

                    const left = document.createElement("div");
                    left.className = "flex flex-col items-start";

                    const invoiceLabel = document.createElement("p");
                    invoiceLabel.className =
                      "text-[11px] sm:text-xs font-bold uppercase tracking-[0.06em] text-[#737686]";
                    invoiceLabel.innerHTML = `N° de documento: <span class="ml-1 text-base sm:text-lg font-extrabold text-[#111827] tracking-normal font-[system-ui]">${item.c_invoice_id}</span>`;
                    left.appendChild(invoiceLabel);

                    if (item.fecha_docto) {
                      const badge = document.createElement("div");
                      badge.className =
                        "mt-3 inline-flex items-center gap-1.5 rounded-lg bg-[#edf2fc] px-2.5 py-1.5 text-[11px] sm:text-xs font-semibold text-[#4b5563]";

                      const icon = document.createElement("span");
                      icon.className =
                        "material-symbols-outlined text-[16px] text-[#4b5563] select-none";
                      icon.textContent = "calendar_today";

                      const textSpan = document.createElement("span");
                      textSpan.textContent = `Fecha de compromiso de pago: ${item.fecha_docto}`;

                      badge.appendChild(icon);
                      badge.appendChild(textSpan);
                      left.appendChild(badge);
                    }

                    const right = document.createElement("div");
                    right.className = "text-right flex flex-col items-end";

                    const amountLabel = document.createElement("p");
                    amountLabel.className =
                      "text-[10px] sm:text-xs font-bold uppercase tracking-[0.08em] text-[#737686]";
                    amountLabel.textContent = "Monto deuda:";

                    const amountValue = document.createElement("p");
                    amountValue.className =
                      "mt-1 font-[Manrope] text-2xl sm:text-3xl font-extrabold text-[#003fb1]";
                    amountValue.textContent = currency.format(item.monto);

                    right.appendChild(amountLabel);
                    right.appendChild(amountValue);

                    row.appendChild(left);
                    row.appendChild(right);
                    debtBreakdown.appendChild(row);
                  }
                }

                for (const item of gestionItems) {
                  const row = document.createElement("article");
                  row.className =
                    "relative mt-[25px] rounded-2xl border border-dashed bg-white/50 p-4 pt-7 sm:p-5 sm:pt-7 shadow-none flex justify-between items-start gap-3";

                  const status = document.createElement("p");
                  status.className =
                    "absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed border-[#d1d5db] bg-[#f8fafc] px-3 py-1 text-[9px] sm:text-[10px] font-bold uppercase tracking-[0.05em] text-[#6b7280] whitespace-nowrap";

                  status.textContent = "* Documento en proceso de cobro";

                  const left = document.createElement("div");
                  left.className = "flex flex-col items-start";

                  const invoiceLabel = document.createElement("p");
                  invoiceLabel.className =
                    "mt-1 text-[10px] sm:text-[11px] font-medium uppercase tracking-[0.05em] text-[#6b7280]";
                  invoiceLabel.innerHTML = `N° de documento: <span class="ml-1 text-sm sm:text-base font-medium text-[#a2a8b2] tracking-normal font-[system-ui]">${item.c_invoice_id}</span>`;
                  left.appendChild(invoiceLabel);

                  if (item.fecha_docto) {
                    const badge = document.createElement("div");
                    badge.className =
                      "mt-2 inline-flex items-center gap-1.5 rounded-lg bg-[#f3f4f6] px-2 py-1.5 text-[10px] sm:text-[11px] font-semibold text-[#6b7280]";

                    const icon = document.createElement("span");
                    icon.className =
                      "material-symbols-outlined text-[16px] text-[#6b7280] select-none";
                    icon.textContent = "pending_actions";

                    const textSpan = document.createElement("span");
                    textSpan.textContent = `Fecha de compromiso de pago: ${item.fecha_docto}`;

                    badge.appendChild(icon);
                    badge.appendChild(textSpan);
                    left.appendChild(badge);
                  }

                  const right = document.createElement("div");
                  right.className = "text-right flex flex-col items-end";

                  const amountLabel = document.createElement("p");
                  amountLabel.className =
                    "text-[9px] sm:text-[10px] font-medium uppercase tracking-[0.08em] text-[#6b7280]";
                  amountLabel.textContent = "Monto deuda:";

                  const amountValue = document.createElement("p");
                  amountValue.className =
                    "mt-1 font-[Manrope] text-xl sm:text-2xl font-semibold text-[#a2a8b2]";
                  amountValue.textContent = currency.format(item.monto);

                  right.appendChild(amountLabel);
                  right.appendChild(amountValue);

                  row.appendChild(left);
                  row.appendChild(right);
                  row.appendChild(status);
                  debtBreakdown.appendChild(row);
                }

                if (gestionItems.length > 0) {
                  const note = document.createElement("p");
                  note.className = "mt-3 text-xs text-[#6b7280]";
                  note.textContent =
                    "*No es posible realizar el pago manual de documentos en proceso de cobro, debido a que están incluidos en un flujo de cobro automático.";
                  debtBreakdown.appendChild(note);
                }
              }

              await hideOverlay();

              setMessage(
                "success",
                "Encontramos una deuda pendiente asociada.",
              );

              if (resultCard instanceof HTMLElement) {
                resultCard.classList.remove("hidden");
                setTimeout(() => {
                  resultCard.scrollIntoView({
                    behavior: "smooth",
                    block: "start",
                  });
                }, 50);
              }
              if (payButton instanceof HTMLButtonElement) {
                payButton.hidden = !hasPayableItems;
                payButton.classList.toggle("hidden", !hasPayableItems);
              }
              if (reviewButton instanceof HTMLButtonElement) {
                reviewButton.hidden = true;
                reviewButton.classList.add("hidden");
              }
            } catch {
              await hideOverlay();
              setMessage("error", "No fue posible realizar la consulta.");
            } finally {
              if (reviewButton instanceof HTMLButtonElement) {
                reviewButton.disabled = false;
              }
            }
          });

          payButton?.addEventListener("click", async () => {
            if (!(payButton instanceof HTMLButtonElement)) {
              return;
            }

            const logo = document.querySelector("#pay-button-logo");
            const spinner = document.querySelector("#pay-button-spinner");
            const btnText = document.querySelector("#pay-button-text");

            payButton.disabled = true;
            if (logo) logo.classList.add("hidden");
            if (spinner) spinner.classList.remove("hidden");
            if (btnText) btnText.textContent = "Preparando pago...";

            setMessage("info", "Preparando pago seguro...");
            setFlowStep(3);

            const requestBody = payableRut
              ? { rut: payableRut }
              : { email: payableEmail };

            try {
              const response = await fetch("/api/crear-pago", {
                method: "POST",
                headers: {
                  "content-type": "application/json",
                },
                body: JSON.stringify(requestBody),
              });
              const data = (await response.json()) as {
                init_point?: string;
                transaction_id?: string;
                error?: string;
                status?: number;
              };

              if (!response.ok || !data.init_point) {
                const reason =
                  data.error === "mercado_pago_no_configurado"
                    ? "Mercado Pago no esta configurado para esta prueba."
                    : data.error === "mercado_pago_error"
                      ? "Mercado Pago rechazo la preferencia."
                      : data.error === "mercado_pago_sin_url"
                        ? "Mercado Pago respondio sin URL de checkout."
                        : data.error === "deuda_no_encontrada"
                          ? "No hay deuda activa para los datos ingresados."
                          : "No fue posible iniciar el pago.";
                setMessage(
                  "error",
                  `${reason}${data.status ? ` (HTTP ${data.status})` : ""}`,
                );
                payButton.disabled = false;
                if (logo) logo.classList.remove("hidden");
                if (spinner) spinner.classList.add("hidden");
                if (btnText) btnText.textContent = "Ir a pagar";
                setFlowStep(2);
                return;
              }

              setFlowStep(3);
              window.location.href = data.init_point;
            } catch {
              setMessage("error", "No fue posible iniciar el pago.");
              payButton.disabled = false;
              if (logo) logo.classList.remove("hidden");
              if (spinner) spinner.classList.add("hidden");
              if (btnText) btnText.textContent = "Ir a pagar";
              setFlowStep(2);
            }
          });
        </script>
      </section>
    </main>
  </body>
</html>
