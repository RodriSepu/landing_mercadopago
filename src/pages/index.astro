        </svg>
      </div>
    </header>

    <main>
      <section
        id="consulta"
        class="relative overflow-hidden px-4 py-12 sm:px-6 sm:py-16 lg:py-20"
      >
        <div
          class="absolute inset-x-0 top-0 h-64 bg-[linear-gradient(180deg,#edf2ff_0%,rgba(247,248,251,0)_100%)]"
        >
        </div>
        <div class="relative mx-auto flex max-w-6xl flex-col items-center justify-center gap-6">
          <section
            class="relative w-full sm:w-[600px] rounded-xl border border-[#e5e7eb] bg-white p-5 shadow-xl shadow-[#d8deeb]/70 sm:p-7"
          >
            <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[#e5e7eb] bg-white px-4 py-2 text-center shadow-sm sm:px-6 sm:py-2.5">
              <h2 class="whitespace-nowrap font-[Manrope] text-[10px] font-extrabold uppercase tracking-[0.06em] text-[#111827] sm:text-[1.1rem] sm:tracking-[0.08em]">
                Verificar deuda pendiente
              </h2>
            </div>
            <div class="pt-4">
              <p class="text-sm leading-6 text-[#4b5563]">
                Mantén tus pagos actualizados para seguir accediendo sin
                interrupciones a la experiencia de suscriptor de <strong>La Tercera</strong>.
              </p>
            </div>

            <div class="mt-6 p-0">
              <div class="mt-4 flex items-center">
                <div id="flow-step-1" class="flow-dot flow-dot--active">1</div>
                <div class="flow-line"></div>
                <div id="flow-step-2" class="flow-dot flow-dot--idle">2</div>
                <div class="flow-line"></div>
                <div id="flow-step-3" class="flow-dot flow-dot--idle">3</div>
              </div>
              <div
                class="mt-3 grid grid-cols-3 text-xs font-semibold text-[#6b7280]"
              >
                <span class="text-start">Identificación</span>
                <span class="text-center">Detalle de la deuda</span>
                <span class="text-end">Confirmación de pago</span>
              </div>
            </div>

            <!-- Selector de pestañas -->
            <div class="mt-6 flex border-b border-[#e5e7eb]">
              <button
                id="tab-rut"
                type="button"
                class="flex-1 pb-3 text-sm font-bold text-[#003fb1] border-b-2 border-[#003fb1] outline-none transition"
              >
                Buscar por RUT
              </button>
              <button
                id="tab-email"
                type="button"
                class="flex-1 pb-3 text-sm font-semibold text-[#737686] border-b-2 border-transparent hover:text-[#111827] outline-none transition"
              >
                Buscar por Correo
              </button>
            </div>

            <form id="debt-form" class="mt-5">
              <div id="container-rut">
                <label for="rut" class="text-sm font-bold text-[#111827]"
                  >RUT</label
                >
                <div class="relative mt-2">
                  <span
                    class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#737686]"
                    >person_search</span
                  >
                  <input
                    id="rut"
                    name="rut"
                    type="text"
                    inputmode="text"
                    autocomplete="off"
                    placeholder="12.345.678-9"
                    required
                    class="min-h-14 w-full rounded-lg border border-[#c3c5d7] bg-[#f8f9fa] pl-12 pr-4 font-[system-ui] text-lg font-semibold text-[#111827] outline-none transition focus:border-[#003fb1] focus:bg-white focus:ring-4 focus:ring-[#003fb1]/15"
                  />
                </div>
              </div>

              <div id="container-email" class="hidden">
                <label for="email" class="text-sm font-bold text-[#111827]"
                  >Correo electrónico</label
                >
                <div class="relative mt-2">
                  <span
                    class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#737686]"
                    >mail</span
                  >
                  <input
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="off"
                    placeholder="ejemplo@correo.com"
                    class="min-h-14 w-full rounded-lg border border-[#c3c5d7] bg-[#f8f9fa] pl-12 pr-4 font-[system-ui] text-lg font-semibold text-[#111827] outline-none transition focus:border-[#003fb1] focus:bg-white focus:ring-4 focus:ring-[#003fb1]/15"
                  />
                </div>
              </div>

              <button
                id="review-button"
                type="submit"
                class="mt-6 inline-flex min-h-14 w-full cursor-pointer items-center justify-center gap-2 rounded-lg bg-[#2e71ea] px-6 text-base font-bold text-white shadow-sm transition hover:bg-[#1a56db] active:scale-[0.99] disabled:cursor-not-allowed disabled:bg-[#9ca3af]"
              >
                Revisar deuda
                <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
              </button>
            </form>

            <div
              id="loading-state"
              class="mt-5 hidden items-center gap-3 rounded-lg border border-[#dbeafe] bg-[#eff6ff] p-4 text-sm font-semibold text-[#1e40af]"
              aria-live="polite"
            >
              <svg
                class="h-5 w-5 animate-spin text-[#1e40af]"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
              >
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
              </svg>
              <span>Comprobando si tienes deuda pendiente...</span>
            </div>

            <div
              id="message-area"
              class="mt-5 min-h-12 rounded-lg border border-transparent p-4 text-sm"
              aria-live="polite"
            >
              <div class="flex items-center gap-2 text-[#434654]">
                <span
                  class="material-symbols-outlined text-[20px] text-[#059669]"
                  >shield</span
                >
                <span
                  >Tus datos se usan solo para consultar la deuda pendiente.</span
                >
              </div>
            </div>

            <section
              id="result-card"
              class="mt-5 hidden rounded-xl border border-[#e5e7eb] bg-[#f8f9fa] p-5"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3
                    id="debt-name"
                    class="mt-2 font-[Manrope] text-xl font-bold text-[#111827]"
                  >
                  </h3>
                </div>
                <div
                  class="rounded-full bg-[#ffdad6] px-3 py-1 text-xs font-bold uppercase tracking-[0.06em] text-[#93000a]"
                >
                  Deuda Pendiente
                </div>
              </div>
              <div
                class="mt-4 rounded-[24px] border border-[#e1e6f7] bg-[#f2f4fe] p-5 sm:p-7"
              >
                <p
                  id="breakdown-title"
                  class="text-xs font-bold uppercase tracking-[0.08em] text-[#737686]"
                >
                  DOCUMENTOS PENDIENTES
                </p>
                <div id="debt-breakdown" class="mt-4 grid gap-3"></div>
                <div
                  class="mt-6 flex items-center justify-between gap-4 border-t border-[#dbe1ff] pt-6"
                >
                  <dt
                    class="font-[Manrope] text-base sm:text-lg font-extrabold text-[#111827] uppercase tracking-wider"
                  >
                    Total a pagar
                  </dt>
                  <dd
                    id="debt-amount"
                    class="font-[Manrope] text-3xl sm:text-4xl font-extrabold text-[#003fb1]"
                  >
                  </dd>
                </div>
              </div>
              <button
                id="pay-button"
                type="button"
                class="mt-5 inline-flex min-h-14 w-full cursor-pointer items-center justify-center gap-2 rounded-lg bg-[#ffe600] px-6 text-base font-bold text-[#111827] transition active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-90"
              >
                <svg
                  id="pay-button-logo"
                  class="payment-method-logo__image--icon_mercado_pago_yellow"
                  width="40"
                  height="40"
                  viewBox="0 0 40 40"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  ><g clip-path="url(#clip0_1262_80327)"
                    ><rect
                      width="40"
                      height="40"
                      rx="20"
                      fill="white"
                      style="mix-blend-mode: luminosity;"></rect><rect
